# 忽略视频和文档
*.mp4
*.pptx
*.docx

# 忽略图片和画图文件
*.png
*.jpg
*.jpeg
*.svg
*.drawio.png

# 忽略 Python 生成的缓存垃圾文件
__pycache__/
*.pyc

# 忽略巨大的数据集和模型权重文件夹
DeepFashion_Data/
images/
models/
weights/
P1_Dataset/
P2_Dataset/
P3_Dataset/
P4_Dataset/
P5_Dataset/

# 忽略 Python 虚拟环境
.venv/

# 前端依赖与构建产物
frontend/node_modules/
frontend/dist/

# 前端 public/editorial 目录下的 JPG 资源允许纳入版本管理
!frontend/public/
!frontend/public/editorial/
!frontend/public/editorial/*.jpg

# 忽略vscode文件夹下的个人设置
.vscode/*

# 其他 IDE / 工具目录
.idea/
.codex/
